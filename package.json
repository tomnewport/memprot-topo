{
  "name": "memprot2d",
  "version": "0.0.0",
  "description": "A browser-based SVG web component for visualising membrane protein 2D topology",
  "type": "module",
  "main": "dist/memprot2d.cjs",
  "module": "dist/memprot2d.js",
  "exports": {
    ".": {
      "import": "./dist/memprot2d.js",
      "require": "./dist/memprot2d.cjs"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx --no-error-on-unmatched-pattern",
    "lint:fix": "eslint src --ext .ts,.tsx --fix --no-error-on-unmatched-pattern",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test --pass-with-no-tests",
    "build:demo": "vite build --config vite.config.demo.ts",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@playwright/test": "^1.44.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^10.1.3",
    "@semantic-release/npm": "^12.0.1",
    "@typescript-eslint/eslint-plugin": "^7.10.0",
    "@typescript-eslint/parser": "^7.10.0",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.1.3",
    "husky": "^9.0.11",
    "jsdom": "^29.1.1",
    "lint-staged": "^15.2.5",
    "prettier": "^3.3.0",
    "semantic-release": "^24.0.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vitest": "^1.6.0"
  }
}
